// Sistem Rekod Aktiviti Pelajar ADTEC KT — Jabatan Tenaga Manusia (JTM) Malaysia
// Prisma schema — PostgreSQL (Supabase production)
// Local dev: use Supabase too (set DATABASE_URL in .env)

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Reference data
// ---------------------------------------------------------------------------

model Bengkel {
  id          String   @id @default(uuid()) @db.Uuid
  namaBengkel String   @unique @map("nama_bengkel")
  createdAt   DateTime @default(now()) @map("created_at")

  profiles   Profile[]
  aktiviti   Aktiviti[]

  @@map("bengkel")
}

model Negeri {
  id         String   @id @default(uuid()) @db.Uuid
  namaNegeri String   @unique @map("nama_negeri")
  createdAt  DateTime @default(now()) @map("created_at")

  daerah   Daerah[]
  aktiviti Aktiviti[]

  @@map("negeri")
}

model Daerah {
  id         String   @id @default(uuid()) @db.Uuid
  namaDaerah String   @map("nama_daerah")
  negeriId   String   @map("negeri_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  negeri    Negeri   @relation(fields: [negeriId], references: [id], onDelete: Cascade)
  aktiviti  Aktiviti[]

  @@unique([namaDaerah, negeriId])
  @@map("daerah")
}

// ---------------------------------------------------------------------------
// Users / Profiles — custom auth (scrypt password hashing)
// ---------------------------------------------------------------------------

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  fullName      String   @map("full_name")
  role          String
  // Scrypt-hashed password (used by our custom auth — NOT Supabase Auth)
  passwordHash  String?  @map("password_hash")
  // Active flag for soft-deactivate (admin)
  active        Boolean  @default(true)
  bengkelId     String?  @map("bengkel_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  bengkel              Bengkel?  @relation(fields: [bengkelId], references: [id])
  diciptaAktiviti      Aktiviti[] @relation("AktivitiDiciptaOleh")
  disemakAktiviti      Aktiviti[] @relation("AktivitiDisemakOleh")
  disahkanAktiviti     Aktiviti[] @relation("AktivitiDisahkanOleh")
  auditLogs            AuditLog[]
  notifications        Notification[]
  sessions             Session[]

  @@map("profiles")
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  token       String   @unique
  profileId   String   @map("profile_id") @db.Uuid
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Aktiviti (main transactional table)
// ---------------------------------------------------------------------------

model Aktiviti {
  id              String   @id @default(uuid()) @db.Uuid
  tarikhPelaksanaan DateTime @map("tarikh_pelaksanaan") @db.Date
  namaAktiviti    String   @map("nama_aktiviti")
  bengkelId       String   @map("bengkel_id") @db.Uuid
  negeriId        String   @map("negeri_id") @db.Uuid
  daerahId        String   @map("daerah_id") @db.Uuid
  namaPengurusAktiviti String @map("nama_pengurus_aktiviti")
  status          String   @default("draf")
  catatanPenolakan String? @map("catatan_penolakan")
  diciptaOleh     String   @map("dicipta_oleh") @db.Uuid
  disemakOleh     String?  @map("disemak_oleh") @db.Uuid
  disahkanOleh    String?  @map("disahkan_oleh") @db.Uuid
  dihantarSemakanPada  DateTime? @map("dihantar_semakan_pada")
  dihantarPengesahanPada DateTime? @map("dihantar_pengesahan_pada")
  disahkanPada    DateTime? @map("disahkan_pada")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bengkel     Bengkel  @relation(fields: [bengkelId], references: [id])
  negeri      Negeri   @relation(fields: [negeriId], references: [id])
  daerah      Daerah   @relation(fields: [daerahId], references: [id])
  pencipta    Profile  @relation("AktivitiDiciptaOleh", fields: [diciptaOleh], references: [id])
  penyemak    Profile? @relation("AktivitiDisemakOleh", fields: [disemakOleh], references: [id])
  pengesah    Profile? @relation("AktivitiDisahkanOleh", fields: [disahkanOleh], references: [id])
  auditLogs   AuditLog[]

  @@index([status])
  @@index([diciptaOleh])
  @@index([tarikhPelaksanaan])
  @@index([negeriId])
  @@index([daerahId])
  @@index([bengkelId])
  @@map("aktiviti")
}

// ---------------------------------------------------------------------------
// Audit log (append-only — Admin can read; Pengajar/Penyelaras/PP only append)
// ---------------------------------------------------------------------------

model AuditLog {
  id          Int      @id @default(autoincrement())
  aktivitiId  String   @map("aktiviti_id") @db.Uuid
  tindakan    String
  olehId      String   @map("oleh_id") @db.Uuid
  catatan     String?
  diciptaPada DateTime @default(now()) @map("dicipta_pada")

  aktiviti Aktiviti @relation(fields: [aktivitiId], references: [id], onDelete: Cascade)
  oleh     Profile  @relation(fields: [olehId], references: [id])

  @@index([aktivitiId])
  @@index([olehId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// In-app notifications (Pengajar gets notified when records are returned)
// ---------------------------------------------------------------------------

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  profileId   String   @map("profile_id") @db.Uuid
  title       String
  message     String
  type        String   @default("system")
  read        Boolean  @default(false)
  aktivitiId  String?  @map("aktiviti_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, read])
  @@map("notifications")
}
